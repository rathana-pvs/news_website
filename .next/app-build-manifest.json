{
  "pages": {
    "/[locale]/(frontend)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/[locale]/(frontend)/layout.css",
      "static/chunks/app/[locale]/(frontend)/layout.js"
    ],
    "/[locale]/(frontend)/loading": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/(frontend)/loading.js"
    ],
    "/[locale]/(frontend)/category/[slug]/loading": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/(frontend)/category/[slug]/loading.js"
    ],
    "/[locale]/(frontend)/category/[slug]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/(frontend)/category/[slug]/page.js"
    ],
    "/[locale]/(frontend)/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/(frontend)/page.js"
    ],
    "/(payload)/api/[...slug]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(payload)/api/[...slug]/route.js"
    ],
    "/(payload)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(payload)/layout.css",
      "static/chunks/app/(payload)/layout.js"
    ],
    "/(payload)/admin/[[...segments]]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(payload)/admin/[[...segments]]/page.css",
      "static/chunks/app/(payload)/admin/[[...segments]]/page.js"
    ],
    "/[locale]/(frontend)/about/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/(frontend)/about/page.js"
    ],
    "/[locale]/(frontend)/search/loading": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/(frontend)/search/loading.js"
    ],
    "/[locale]/(frontend)/search/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[locale]/(frontend)/search/page.js"
    ]
  }
